{
  "diagnostics.disable": ["lowercase-global"],
  "diagnostics.globals": ["playdate", "import", "json"],
  "diagnostics.severity": { "duplicate-set-field": "Hint" },
  "format.defaultConfig": { "indent_style": "space", "indent_size": "2" },
  "runtime.builtin": { "io": "disable", "os": "disable", "package": "disable" },
  "runtime.nonstandardSymbol": ["+=", "-=", "*=", "/=", "//=", "%=", "<<=", ">>=", "&=", "|=", "^="],
  "runtime.version": "Lua 5.4",
  "workspace.preloadFileSize": 1000,
  "workspace.useGitIgnore": false,
  "workspace.library": ["library/playdate-luacats"]
}
