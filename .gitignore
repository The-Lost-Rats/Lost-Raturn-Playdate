# Ignore everything by default
/*
/*/
.*

# Whitelist git files
!.gitignore
!.github/

# Whitelist documentation
!README.md
!LICENSE

# Whitelist makefile
!Makefile

# Whitelist source lua files
!source
source/**

!source/**/
!source/**/*.lua

# Whitelist assets
!source/images/**/
!source/images/**/*.png

# Whitelist playdate files
!source/pdxinfo
